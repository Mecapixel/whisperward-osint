# WhisperWard OSINT - .gitignore

# Session signing secret (generated at first run, never commit)
.ww_session_secret

# Database files
whisperward.db
*.db
*.sqlite3

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
env.bak/
venv.bak/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo

# Project specific outputs
exports/
reports/
logs/
temp/
tmp/

# Logs
*.log

# Environment variables
.env
.env.local

# Large binary files
*.zip
*.rar

# External tools (cloned separately)
sherlock/

# AI / RAG storage
knowledge_base/chroma/
# M4 generated threat data
data/threat_intel/tor_exit_nodes.txt
data/threat_intel/tor_exit_nodes.meta.json
data/geoip/
data/proxy/

data/signing/

